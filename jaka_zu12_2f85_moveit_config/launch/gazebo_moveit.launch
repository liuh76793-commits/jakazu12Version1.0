<launch>
  <include file="$(find jaka_zu12_2f85_moveit_config)/launch/planning_context.launch">
    <arg name="load_robot_description" value="false"/>
  </include>

  <include file="$(find jaka_zu12_2f85_moveit_config)/launch/trajectory_execution.launch.xml">
    <arg name="moveit_manage_controllers" value="false"/>
    <arg name="moveit_controller_manager" value="simple"/>
  </include>

  <include file="$(find jaka_zu12_2f85_moveit_config)/launch/move_group.launch">
    <arg name="allow_trajectory_execution" value="true"/>
    <arg name="publish_monitored_planning_scene" value="true"/>
  </include>

  <include file="$(find jaka_zu12_2f85_moveit_config)/launch/moveit_rviz.launch"/>
</launch>
