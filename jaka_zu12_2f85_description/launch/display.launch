<launch>
  <param name="robot_description"
         command="$(find xacro)/xacro '$(find jaka_zu12_2f85_description)/urdf/jaka_zu12_2f85.urdf.xacro'" />

  <node name="joint_state_publisher_gui"
        pkg="joint_state_publisher_gui"
        type="joint_state_publisher_gui" />

  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher" />

  <node name="rviz"
        pkg="rviz"
        type="rviz"
        args="-d $(find jaka_zu12_2f85_description)/rviz/jaka_zu12_2f85.rviz"
        required="true" />
</launch>
